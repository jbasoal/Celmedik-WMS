rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Adjuntos por usuario (cuenta owner). Solo el propietario del path
    // puede escribir; cualquier usuario autenticado puede leer para permitir
    // descargar documentos asociados a movimientos compartidos dentro de la
    // misma organización.
    match /usuarios/{uid}/adjuntos/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid
                   && request.resource.size < 20 * 1024 * 1024;
    }
    // Cualquier otro path queda cerrado por defecto.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
