{
  "rules": {
    "usuarios": {
      ".read": "auth != null && root.child('usuarios').child(auth.uid).child('perfil').val() === 'Maestro'",
      "$uid": {
        ".read": "$uid === auth.uid || root.child('usuarios').child(auth.uid).child('maestroUid').val() === $uid || root.child('usuarios').child(auth.uid).child('perfil').val() === 'Maestro'",
        ".write": "$uid === auth.uid || root.child('usuarios').child(auth.uid).child('maestroUid').val() === $uid || root.child('usuarios').child(auth.uid).child('perfil').val() === 'Maestro'"
      }
    },
    "organizaciones": {
      "$orgId": {
        ".read": "auth != null",
        ".write": "auth != null && (auth.uid === $orgId || root.child('usuarios').child(auth.uid).child('maestroUid').val() === $orgId)"
      }
    },
    "tracking": {
      ".read": true,
      ".write": "auth != null"
    }
  }
}
